{
  "_comment": "Realtime Database rules for Quy's Toolkit. Paste the contents of `rules` into Firebase Console -> Realtime Database -> Rules -> Publish. Sensitive nodes (admins, inviteEmails, feedback, announcement, presence, leaderboard) stay locked down. Everything else -- any current or FUTURE realtime tool (rooms, games, shared state) -- is matched by the `$other` wildcard and gets public read/write, so new tools work without ever editing these rules again. Named rules take precedence over the wildcard, so the locked nodes remain protected.",
  "rules": {
    "presence": {
      ".read": true,
      "$uid": { ".write": "auth != null && auth.uid === $uid" }
    },

    "leaderboard": {
      ".read": true,
      "$game": {
        "$uid": { ".write": "auth != null && auth.uid === $uid" }
      }
    },

    "feedback": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      "$id": {
        ".write": "!data.exists() || (auth != null && root.child('admins').child(auth.uid).exists())",
        ".validate": "newData.hasChildren(['text','category','createdAt'])"
      }
    },

    "announcement": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    "admins": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && ((auth.uid === $uid && (auth.token.email === 'khucxuanquy@gmail.com' || root.child('inviteEmails').child(auth.token.email.replace('.', ',')).exists())) || root.child('admins').child(auth.uid).child('role').val() === 'super')"
      }
    },

    "inviteEmails": {
      ".read": "auth != null",
      "$emailKey": {
        ".write": "auth != null && (root.child('admins').child(auth.uid).child('role').val() === 'super' || (auth.token.email != null && auth.token.email.replace('.', ',') === $emailKey))"
      }
    },

    "$other": {
      ".read": true,
      ".write": true
    }
  }
}
