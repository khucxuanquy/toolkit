{
  "_comment": "Recommended Realtime Database rules for Quy's Toolkit. Paste the contents of `rules` into Firebase Console -> Realtime Database -> Rules. Super admin is gated by email (khucxuanquy@gmail.com); other admins self-register from an invite stored under inviteEmails. The client-side gate in the app is UX only -- these rules are the real protection for who can READ feedback and WRITE admin data. Guests (not signed in) can still use Music Room and submit feedback.",
  "rules": {
    "presence": {
      ".read": true,
      "$uid": { ".write": "auth != null && auth.uid === $uid" }
    },

    "leaderboard": {
      ".read": true,
      "$game": {
        "$uid": { ".write": "auth != null && auth.uid === $uid" }
      }
    },

    "musicRooms": {
      ".read": true,
      ".write": true
    },

    "feedback": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      "$id": {
        ".write": "!data.exists() || (auth != null && root.child('admins').child(auth.uid).exists())",
        ".validate": "newData.hasChildren(['text','category','createdAt'])"
      }
    },

    "announcement": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    "admins": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && ((auth.uid === $uid && (auth.token.email === 'khucxuanquy@gmail.com' || root.child('inviteEmails').child(auth.token.email.replace('.', ',')).exists())) || root.child('admins').child(auth.uid).child('role').val() === 'super')"
      }
    },

    "inviteEmails": {
      ".read": "auth != null",
      "$emailKey": {
        ".write": "auth != null && (root.child('admins').child(auth.uid).child('role').val() === 'super' || (auth.token.email != null && auth.token.email.replace('.', ',') === $emailKey))"
      }
    }
  }
}
